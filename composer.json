{
  "name": "codex13/webman-auth",
  "description": "webman auth",
  "keywords": ["webman", "auth", "jwt"],
  "version": "1.0.0",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "codex13",
